{
  "name": "nestjs-starter-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "tsc --noEmit",
    "db:migrate": "sequelize-cli db:migrate --config sequelize.config.cjs --migrations-path src/database/migrations",
    "db:migrate:status": "sequelize-cli db:migrate:status --config sequelize.config.cjs --migrations-path src/database/migrations",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config sequelize.config.cjs --migrations-path src/database/migrations",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all --config sequelize.config.cjs --migrations-path src/database/migrations",
    "db:migration:create": "sequelize-cli migration:generate --migrations-path src/database/migrations"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/sequelize": "^11.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "sequelize-cli": "^6.6.5",
    "typescript": "^5.7.2"
  }
}
